# Runtime
RUN_MODE=local

# Server
MEDIA_SERVICE_SERVER_HOST=0.0.0.0
MEDIA_SERVICE_SERVER_PORT=3000
MEDIA_SERVICE_SERVER_MAX_UPLOAD_SIZE=104857600

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=recipe_database
POSTGRES_SCHEMA=recipe_manager
MEDIA_MANAGEMENT_DB_USER=postgres
MEDIA_MANAGEMENT_DB_PASSWORD=changeme

# Storage
MEDIA_SERVICE_STORAGE_BASE_PATH=./media
MEDIA_SERVICE_STORAGE_TEMP_PATH=./media/temp
MEDIA_SERVICE_DOWNLOAD_URL_TTL_SECS=86400
MEDIA_SERVICE_UPLOAD_URL_TTL_SECS=900

# Auth (Dev mode: OAUTH2_SERVICE_ENABLED=false reads x-user-id header)
OAUTH2_SERVICE_ENABLED=false
OAUTH2_INTROSPECTION_ENABLED=false
OAUTH2_SERVICE_BASE_URL=http://localhost:8080/api/v1/auth
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
JWT_SECRET=change-me-to-a-real-secret

# Logging
RUST_LOG=debug

# OpenTelemetry (empty = disabled)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Build (optional: relocate target/ to avoid backing up 5-10GB of build artifacts)
# CARGO_TARGET_DIR=/tmp/cargo-target/media-management-service
