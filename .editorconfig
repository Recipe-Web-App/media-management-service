# EditorConfig - https://editorconfig.org
# Top-level config for media-management-service

root = true

# ── Defaults ──────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ── Rust ──────────────────────────────────────────────────────
# Matches rustfmt defaults (style_edition = 2024)
[*.rs]
indent_size = 4
max_line_length = 100

# ── Shell Scripts ─────────────────────────────────────────────
# Matches shfmt defaults (used in lefthook pre-commit)
[*.{sh,bash}]
indent_size = 2
shell_variant = bash
binary_next_line = true

# ── YAML / Kustomize ─────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── Lefthook (uses 4-space indent, unlike other YAML) ────────
[lefthook.yml]
indent_size = 4

# ── TOML (Cargo.toml, rustfmt.toml, deny.toml, etc.) ─────────
[*.toml]
indent_size = 4

# ── JSON / JSONL ──────────────────────────────────────────────
[*.{json,jsonl}]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# ── Dockerfile ────────────────────────────────────────────────
[Dockerfile]
indent_size = 4

# ── Cargo.lock (generated, do not reformat) ───────────────────
[Cargo.lock]
indent_size = 4
insert_final_newline = unset
trim_trailing_whitespace = unset

# ── SQL migrations (if added later) ──────────────────────────
[*.sql]
indent_size = 4
max_line_length = 120
